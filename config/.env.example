# Configurações do FarmTech Solutions
# Copie este arquivo para .env na raiz do projeto e ajuste os valores.
# Não defina PORT no .env local: o main.py usa a ausência de PORT para abrir
# o dashboard em http://localhost:8501. Em deploy, a plataforma define PORT.

# Caminho do banco de dados SQLite (relativo à raiz do projeto)
DB_PATH=src/db/farmtech.db

# Limiar de umidade para acionamento da bomba (%)
UMIDADE_LIMIAR=60.0

# Intervalo do scheduler em segundos
SCHEDULER_INTERVALO=30
